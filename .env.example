# Postgres connection string.
# Local dev (docker-compose): postgresql://padel:padel@localhost:5433/padel_prode
# Production (Neon): postgresql://USER:PASS@HOST-pooler.REGION.neon.tech/DB?sslmode=require
DATABASE_URL="postgresql://padel:padel@localhost:5433/padel_prode"

# Auth.js
AUTH_SECRET="generate-with-openssl-rand-base64-32"

# Resend
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxx"
RESEND_FROM_EMAIL="Padel Prode <onboarding@resend.dev>"

# Email que recibe todas las notificaciones de bienvenida y reset de password.
# Con sandbox de Resend, este tiene que ser el email registrado en la cuenta.
# El admin reenvía los links manualmente a los usuarios por otro canal.
ADMIN_NOTIFICATION_EMAIL="admin@example.com"

# Application
APP_URL="http://localhost:3000"
NODE_ENV="development"
